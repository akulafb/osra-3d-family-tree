# =============================================================================
# LOCAL DEVELOPMENT - Use your DEVELOPMENT Supabase project credentials here.
# This ensures npm run dev writes to the dev database, not production.
# =============================================================================

VITE_SUPABASE_URL=https://your-dev-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_dev_anon_key

# Optional: AI chatbot (cloud mode)
# VITE_OPENROUTER_API_KEY=your_openrouter_key

# Optional: Use local Ollama instead of OpenRouter
# VITE_LLM_MODE=local
