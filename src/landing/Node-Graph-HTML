<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Osra — Node Graph</title>
<!-- Lora from Google Fonts — replace with local @font-face if you have the files:
  @font-face { font-family: 'Lora'; src: url('fonts/Lora-Regular.woff2') format('woff2'); font-weight: 400; }
  @font-face { font-family: 'Lora'; src: url('fonts/Lora-Bold.woff2') format('woff2'); font-weight: 700; }
-->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;700&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: #07030f; height: 700vh; overflow-x: hidden; }

  #sticky-container {
    position: sticky; top: 0;
    width: 100%; height: 100vh; overflow: hidden;
  }
  canvas { display: block; position: absolute; top: 0; left: 0; }

  /* ── HUD ── */
  #hud {
    position: absolute; top: 28px; left: 50%;
    transform: translateX(-50%); text-align: center;
    pointer-events: none; z-index: 10;
  }
  #node-count {
    font-family: 'Lora', Georgia, serif;
    font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase;
    color: #c4b5fd; opacity: 0.4;
  }
  #scroll-hint {
    font-family: 'Lora', Georgia, serif;
    font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase;
    color: #c4b5fd; margin-top: 6px; transition: opacity 0.8s;
  }

  /* ═══════════════════════════════════════
     DESKTOP layout (>768px)
     ───────────────────────────────────────
     Graph:      top 50vh
     Air:        middle 25vh
     Text zone:  bottom 25vh
       title → bottom-left
       body  → bottom-right
     ═══════════════════════════════════════ */

  #hero-title, #hero-body {
    position: absolute;
    pointer-events: none;
    z-index: 20;
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 1.4s ease, transform 1.4s ease;
  }
  #hero-title.visible,
  #hero-body.visible {
    opacity: 1;
    transform: translateY(0);
  }

  #hero-title {
    bottom: 4vh;
    left: 6vw;
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    font-size: clamp(52px, 5.5vw, 88px);
    line-height: 1;
    letter-spacing: -0.015em;
    color: #ede9fe;
    white-space: nowrap;
  }

  #hero-body {
    bottom: 4vh;
    right: 6vw;
    text-align: right;
    font-family: 'Lora', Georgia, serif;
    font-weight: 400;
    font-size: clamp(13px, 1.1vw, 18px);
    line-height: 1.7;
    color: #7c5cbf;
    max-width: 40ch;
  }

  /* ═══════════════════════════════════════
     MOBILE layout (≤768px)
     ───────────────────────────────────────
     Graph fills full screen while travelling.
     Title + body are stacked below each other,
     each appearing as a new sticky "slide" —
     achieved by making the sticky container
     taller and revealing text via scroll %.
     ═══════════════════════════════════════ */
  @media (max-width: 768px) {
    #hero-title {
      bottom: auto;
      left: 0; right: 0;
      top: 50%;
      transform: translateY(calc(-50% + 14px));
      text-align: center;
      font-size: clamp(44px, 11vw, 72px);
      white-space: nowrap;
    }
    #hero-title.visible {
      transform: translateY(-50%);
    }

    #hero-body {
      bottom: auto;
      left: 0; right: 0;
      top: 50%;
      transform: translateY(calc(-50% + 14px));
      text-align: center;
      font-size: clamp(14px, 3.8vw, 20px);
      max-width: 80vw;
      margin: 0 auto;
      /* right: auto needed to not conflict */
      right: 0;
    }
    #hero-body.visible {
      transform: translateY(-50%);
    }
  }

  /* shining words */
  .shine {
    color: #ffffff;
    text-shadow:
      0 0 10px rgba(255,255,255,0.95),
      0 0 26px rgba(196,181,253,0.7),
      0 0 55px rgba(124,58,237,0.45);
  }
</style>
</head>
<body>
<div id="sticky-container">
  <canvas id="c"></canvas>

  <div id="hud">
    <div id="node-count">1 node</div>
    <div id="scroll-hint">scroll to travel</div>
  </div>

  <div id="hero-title">Meet Osra</div>
  <div id="hero-body">
    <span class="shine">Osra</span> is a beautiful, interactive, and fully immersive family tree experience.
    Built for <span class="shine">privacy and performance</span>, Osra gives every family their own universe
    to explore, in <span class="shine">stunning</span> 3D space.
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
// ─── Seeded RNG ────────────────────────────────────────────
let _s = 0xdeadbeef;
function rng() {
  _s ^= _s << 13; _s ^= _s >> 17; _s ^= _s << 5;
  return (_s >>> 0) / 0xffffffff;
}

// ─── Renderer ─────────────────────────────────────────────
const canvas = document.getElementById('c');
const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.setClearColor(0x07030f, 1);

const scene = new THREE.Scene();
scene.fog = new THREE.FogExp2(0x07030f, 0.012); // very light — wide open

const camera = new THREE.PerspectiveCamera(45, 1, 0.05, 300);
camera.position.set(0, 0, 4);

function resize() {
  const w = window.innerWidth, h = window.innerHeight;
  renderer.setSize(w, h);
  camera.aspect = w / h;
  camera.updateProjectionMatrix();
}
resize();
window.addEventListener('resize', resize);

// ─── Lights ───────────────────────────────────────────────
scene.add(new THREE.AmbientLight(0x1a0033, 2.2));
const pl1 = new THREE.PointLight(0x9333ea, 5, 60); pl1.position.set(5, 6, 8); scene.add(pl1);
const pl2 = new THREE.PointLight(0x7c3aed, 3, 50); pl2.position.set(-8,-3, 5); scene.add(pl2);
const pl3 = new THREE.PointLight(0xd8b4fe, 2, 45); pl3.position.set(0, -8,-6); scene.add(pl3);

// ─── Stars ────────────────────────────────────────────────
{
  const n = 1100, p = new Float32Array(n*3);
  for (let i=0;i<n;i++){
    p[i*3]=(rng()-.5)*200; p[i*3+1]=(rng()-.5)*200; p[i*3+2]=(rng()-.5)*200;
  }
  const sg = new THREE.BufferGeometry();
  sg.setAttribute('position', new THREE.BufferAttribute(p,3));
  scene.add(new THREE.Points(sg, new THREE.PointsMaterial({
    color:0xc4b5fd, size:0.09, transparent:true, opacity:0.3
  })));
}

// ─── 50 Nodes — wide spread to fill screen ────────────────
const N = 50;
const nodePositions = [];
while (nodePositions.length < N) {
  // Spread wider on X so graph fills full screen width
  const rx = 4.0 + rng() * 13.0;  // wide
  const ry = 3.5 + rng() * 8.0;   // less tall
  const rz = 2.0 + rng() * 6.0;   // moderate depth
  const theta = rng() * Math.PI * 2;
  const phi   = Math.acos(2*rng()-1);
  const p = new THREE.Vector3(
    rx * Math.sin(phi)*Math.cos(theta),
    ry * Math.sin(phi)*Math.sin(theta) * 0.55,
    rz * Math.cos(phi)
  );
  if (!nodePositions.some(q => q.distanceTo(p) < 1.8)) nodePositions.push(p);
}

// ─── Edges: k=2 nearest — sparse ─────────────────────────
const edgeDefs = [];
const edgeSet  = new Set();
nodePositions.forEach((pos, i) => {
  nodePositions
    .map((p,j) => ({j, d: pos.distanceTo(p)}))
    .filter(x => x.j !== i)
    .sort((a,b) => a.d-b.d)
    .slice(0,2)
    .forEach(({j}) => {
      const k = `${Math.min(i,j)}_${Math.max(i,j)}`;
      if (!edgeSet.has(k)) { edgeSet.add(k); edgeDefs.push([i,j]); }
    });
});

// ─── Adjacency ────────────────────────────────────────────
const adj = Array.from({length:N}, ()=>[]);
edgeDefs.forEach(([a,b]) => { adj[a].push(b); adj[b].push(a); });

// ─── Glow textures ────────────────────────────────────────
function makeGlowTex(inner, outer) {
  const c = document.createElement('canvas'); c.width = c.height = 64;
  const x = c.getContext('2d');
  const g = x.createRadialGradient(32,32,0,32,32,32);
  g.addColorStop(0, inner); g.addColorStop(0.35, outer); g.addColorStop(1,'rgba(0,0,0,0)');
  x.fillStyle = g; x.fillRect(0,0,64,64);
  return new THREE.CanvasTexture(c);
}
const purpleGlowTex = makeGlowTex('rgba(255,200,255,1)','rgba(170,70,255,0.88)');
const whiteGlowTex  = makeGlowTex('rgba(255,255,255,1.0)','rgba(220,200,255,0.6)');

const NODE_BASE_COLOR = 0xff66ff;
const NODE_HOVER_COLOR = 0xffc3ff;
const NODE_EMISSIVE_COLOR = 0x7a1ed8;

// ─── Node objects ─────────────────────────────────────────
const sphereGeo    = new THREE.SphereGeometry(0.18, 24, 24);
const nodeMeshes   = [];
const purpleGlows  = [];
const whiteGlows   = [];
const nodeVisible  = new Array(N).fill(0);
const hoverTarget  = new Array(N).fill(0);
const hoverCurrent = new Array(N).fill(0);

nodePositions.forEach((pos, i) => {
  const mesh = new THREE.Mesh(sphereGeo, new THREE.MeshPhongMaterial({
    color:NODE_BASE_COLOR, emissive:NODE_EMISSIVE_COLOR, emissiveIntensity:1.2,
    specular:0xe9d5ff, shininess:140,
  }));
  mesh.position.copy(pos); mesh.scale.setScalar(0); scene.add(mesh); nodeMeshes.push(mesh);

  const pg = new THREE.Sprite(new THREE.SpriteMaterial({
    map:purpleGlowTex, transparent:true, opacity:0,
    blending:THREE.AdditiveBlending, depthWrite:false,
  }));
  pg.position.copy(pos); pg.scale.setScalar(1.3); scene.add(pg); purpleGlows.push(pg);

  const wg = new THREE.Sprite(new THREE.SpriteMaterial({
    map:whiteGlowTex, transparent:true, opacity:0,
    blending:THREE.AdditiveBlending, depthWrite:false,
  }));
  wg.position.copy(pos); wg.scale.setScalar(2.2); scene.add(wg); whiteGlows.push(wg);
});

// ─── Edge objects — slinky only, no buzz ──────────────────
const SEGS = 18;
const edgeObjects = [];

edgeDefs.forEach(([a,b]) => {
  const posA = nodePositions[a], posB = nodePositions[b];
  const mid  = posA.clone().lerp(posB, 0.5);
  const perp = new THREE.Vector3(rng()-.5, rng()-.5, rng()-.5).normalize();
  const phase     = rng()*Math.PI*2;
  const speed     = 0.25 + rng()*0.4;
  const wobbleAmp = 0.08 + rng()*0.12;

  const pts = [];
  for (let i=0;i<=SEGS;i++) pts.push(new THREE.Vector3());
  const geo = new THREE.BufferGeometry().setFromPoints(pts);
  const posAttr = geo.attributes.position;

  const coreMat = new THREE.LineBasicMaterial({
    color:0xffffff, transparent:true, opacity:0,
    blending:THREE.AdditiveBlending, depthWrite:false,
  });
  const haloMat = new THREE.LineBasicMaterial({
    color:0xd8b4fe, transparent:true, opacity:0,
    blending:THREE.AdditiveBlending, depthWrite:false,
  });

  scene.add(new THREE.Line(geo, coreMat));
  scene.add(new THREE.Line(geo, haloMat));

  edgeObjects.push({ a, b, mid, perp, phase, speed, wobbleAmp, posAttr, coreMat, haloMat });
});

// ─── Camera BFS path — only 5 waypoints ───────────────────
const camPath    = [0];
const camVisited = new Set([0]);
const bfsQ = [0];
while (bfsQ.length && camPath.length < 5) {
  const curr = bfsQ.shift();
  const shuffled = [...adj[curr]].sort(()=>rng()-0.5);
  for (const nxt of shuffled) {
    if (!camVisited.has(nxt) && camPath.length < 5) {
      camVisited.add(nxt); camPath.push(nxt); bfsQ.push(nxt);
    }
  }
}
const nodeRevealOrder = [
  ...camPath,
  ...Array.from({length:N},(_,i)=>i).filter(i=>!camVisited.has(i))
];

// ─── Graph group — for skewer rotation ────────────────────
const graphGroup = new THREE.Group();
nodeMeshes.forEach(m  => { scene.remove(m); graphGroup.add(m); });
purpleGlows.forEach(g => { scene.remove(g); graphGroup.add(g); });
whiteGlows.forEach(g  => { scene.remove(g); graphGroup.add(g); });
edgeObjects.forEach(e => {
  e.coreLine = graphGroup.children[graphGroup.children.length]; // handled below
});
// Re-add the lines to graphGroup
// (They were added to scene directly, move them)
scene.children
  .filter(c => c.isLine)
  .forEach(l => { scene.remove(l); graphGroup.add(l); });
scene.add(graphGroup);

// ─── Input ────────────────────────────────────────────────
let mouseX=0, mouseY=0, smMouseX=0, smMouseY=0;
const _mouse2D = new THREE.Vector2();
window.addEventListener('mousemove', e => {
  mouseX = (e.clientX/window.innerWidth  - 0.5)*2;
  mouseY = (e.clientY/window.innerHeight - 0.5)*2;
  _mouse2D.set((e.clientX/window.innerWidth)*2-1, -(e.clientY/window.innerHeight)*2+1);
});

let scrollTarget=0, scrollSmooth=0;
window.addEventListener('scroll', () => {
  const max = document.body.scrollHeight - window.innerHeight;
  scrollTarget = Math.min(Math.max(window.scrollY/max, 0), 1);
});

// ─── Raycaster ────────────────────────────────────────────
const raycaster = new THREE.Raycaster();
let hoveredIdx = -1;

// ─── DOM refs ─────────────────────────────────────────────
const heroTitleEl  = document.getElementById('hero-title');
const heroBodyEl   = document.getElementById('hero-body');
const nodeCountEl  = document.getElementById('node-count');
const scrollHintEl = document.getElementById('scroll-hint');

// ─── Helpers ──────────────────────────────────────────────
function lerp(a,b,t){ return a+(b-a)*t; }
function clamp01(v){ return Math.min(Math.max(v,0),1); }
function easeOutBack(t){
  const c1=1.70158,c3=c1+1;
  return 1+c3*Math.pow(t-1,3)+c1*Math.pow(t-1,2);
}
function smoothstep(t){ return t*t*(3-2*t); }

const _vB  = new THREE.Vector3();
const _vM  = new THREE.Vector3();
const camPos    = new THREE.Vector3();
const camLookAt = new THREE.Vector3();
const clock = new THREE.Clock();

// Phase: travel ends at scroll 0.18 (quick 5-node journey)
// Pullback: 0.18 → 1.0 (remaining 45 nodes flood in across full view)
const TRAVEL_END = 0.18;
const IS_MOBILE  = window.matchMedia('(max-width: 768px)').matches;

function animate() {
  requestAnimationFrame(animate);
  const t = clock.getElapsedTime();

  scrollSmooth = lerp(scrollSmooth, scrollTarget, 0.055);
  smMouseX     = lerp(smMouseX, mouseX, 0.06);
  smMouseY     = lerp(smMouseY, mouseY, 0.06);

  // ── Skewer rotation — slow, majestic Y-axis spin ──
  // Only rotate during pullback (while in the grand overview)
  const pullT   = clamp01((scrollSmooth - TRAVEL_END) / (1 - TRAVEL_END));
  const rotRate = lerp(0, 0.0018, smoothstep(pullT)); // spins in gradually
  graphGroup.rotation.y += rotRate;

  // ── Node reveal ──
  const revealFront = scrollSmooth < TRAVEL_END
    ? (scrollSmooth / TRAVEL_END) * camPath.length
    : camPath.length + ((scrollSmooth - TRAVEL_END) / (1 - TRAVEL_END)) * (N - camPath.length);

  nodeRevealOrder.forEach((ni, ri) => {
    const vis = clamp01(revealFront - ri);
    nodeVisible[ni] = lerp(nodeVisible[ni], vis > 0 ? easeOutBack(clamp01(vis*3)) : 0, 0.07);
    const s = Math.max(nodeVisible[ni], 0);
    nodeMeshes[ni].scale.setScalar(s);
    const pulse = 0.85 + 0.15*Math.sin(t*1.4 + ni*0.7);
    purpleGlows[ni].material.opacity = s * pulse * 0.65;
    purpleGlows[ni].scale.setScalar(1.2 + 0.15*pulse*s);
  });

  // ── Hover ──
  raycaster.setFromCamera(_mouse2D, camera);
  const hits = raycaster.intersectObjects(nodeMeshes.filter((_,i) => nodeVisible[i] > 0.3));
  const newHovered = hits.length > 0 ? nodeMeshes.indexOf(hits[0].object) : -1;
  if (newHovered !== hoveredIdx) {
    if (hoveredIdx >= 0) hoverTarget[hoveredIdx] = 0;
    if (newHovered >= 0) hoverTarget[newHovered] = 1;
    hoveredIdx = newHovered;
  }
  for (let i=0;i<N;i++) {
    hoverCurrent[i] = clamp01(hoverCurrent[i] + (hoverTarget[i]-hoverCurrent[i]) * 0.016 * 3.5);
    const wg = whiteGlows[i], s = nodeVisible[i];
    wg.material.opacity = hoverCurrent[i] * s * 0.92;
    wg.scale.setScalar((2.2 + hoverCurrent[i]*1.8) * Math.max(s,0));
    nodeMeshes[i].material.emissiveIntensity = 0.7 + hoverCurrent[i]*2.5;
    nodeMeshes[i].material.color.setHex(hoverCurrent[i] > 0.3 ? NODE_HOVER_COLOR : NODE_BASE_COLOR);
  }

  // ── Edges — slinky, no buzz ──
  edgeObjects.forEach(ed => {
    const {a,b,mid,perp,phase,speed,wobbleAmp,posAttr,coreMat,haloMat} = ed;
    const vis = Math.min(nodeVisible[a], nodeVisible[b]);

    const wobble = Math.sin(t*speed+phase) * wobbleAmp;
    _vM.copy(mid).addScaledVector(perp, wobble*vis);

    const pA = nodePositions[a], pB = nodePositions[b];
    for (let j=0;j<=SEGS;j++){
      const u=j/SEGS, ou=1-u;
      posAttr.setXYZ(j,
        pA.x*ou*ou+2*_vM.x*u*ou+pB.x*u*u,
        pA.y*ou*ou+2*_vM.y*u*ou+pB.y*u*u,
        pA.z*ou*ou+2*_vM.z*u*ou+pB.z*u*u
      );
    }
    posAttr.needsUpdate = true;

    const breathe = 0.6 + 0.4*Math.sin(t*speed+phase+0.5);
    const baseOp  = vis > 0.3 ? vis : 0;
    coreMat.opacity = lerp(coreMat.opacity, (0.5 + 0.2*breathe) * baseOp, 0.06);
    haloMat.opacity = lerp(haloMat.opacity, (0.18 + 0.1*breathe) * baseOp, 0.06);
  });

  // ── Camera ──
  if (scrollSmooth < TRAVEL_END) {
    // Travel: fly through 5 nodes
    const pathT  = scrollSmooth / TRAVEL_END;
    const rawIdx = pathT * (camPath.length - 1);
    const segIdx = Math.min(Math.floor(rawIdx), camPath.length-2);
    const segT   = rawIdx - segIdx;

    const nodeA = nodePositions[camPath[segIdx]];
    const nodeB = nodePositions[camPath[segIdx+1]];
    const fwd   = _vB.copy(nodeB).sub(nodeA).normalize();

    camPos.copy(nodeA).addScaledVector(fwd, -1.2 + segT*0.8).addScaledVector(fwd,-0.5);
    camPos.y += 0.25;
    camPos.x += smMouseX * 0.35;
    camPos.y -= smMouseY * 0.35;
    camera.position.lerp(camPos, 0.045);

    camLookAt.copy(nodeB);
    camLookAt.x += smMouseX*0.18;
    camLookAt.y -= smMouseY*0.18;
    camera.lookAt(camLookAt);
    camera.fov = lerp(camera.fov, 42, 0.04);

  } else {
    // Pullback: zoom out to grand overview
    const easedPull = smoothstep(pullT);

    // Elevated camera so graph sits in top 50% of viewport
    // Full-width: Z~26, FOV~68 gives ~30 units half-width at aspect 1.78 => covers radius ~13
    const finalZ = 26;
    const finalY = 5.5; // elevate camera so graph floats in upper half

    // Smoothly transition from travel end position
    const targetZ = lerp(4, finalZ, easedPull);
    const targetY = lerp(0.25, finalY, easedPull);

    camPos.set(
      smMouseX * lerp(0.4, 2.0, easedPull),
      targetY + smMouseY * lerp(-0.3, -1.0, easedPull),
      targetZ
    );
    camera.position.lerp(camPos, 0.035);

    // Look slightly above origin so graph appears in upper half
    camLookAt.set(
      smMouseX * lerp(0.15, 0.6, easedPull),
      lerp(0, 1.8, easedPull),
      0
    );
    camera.lookAt(camLookAt);

    // FOV widens to fill full screen width
    camera.fov = lerp(camera.fov, 42 + easedPull*26, 0.03);
  }
  camera.updateProjectionMatrix();

  // ── Hero text — staggered reveal, mobile-aware ──
  // Desktop: title bottom-left, body bottom-right, both below graph
  // Mobile:  graph full screen → title centred → body centred (each own scroll window)
  let titleThreshold, bodyThreshold;
  if (IS_MOBILE) {
    // On mobile the graph occupies the early scroll;
    // title appears in its own "slide" window, body after another beat
    titleThreshold = TRAVEL_END + (1 - TRAVEL_END) * 0.50; // ~scroll 0.59
    bodyThreshold  = TRAVEL_END + (1 - TRAVEL_END) * 0.76; // ~scroll 0.80
    // On mobile hide body while title is showing (clean single-focus slides)
    const titleOut = TRAVEL_END + (1 - TRAVEL_END) * 0.68; // ~scroll 0.74
    const titleVisible = scrollSmooth > titleThreshold && scrollSmooth < titleOut;
    titleVisible ? heroTitleEl.classList.add('visible') : heroTitleEl.classList.remove('visible');
  } else {
    // Desktop: title ~scroll 0.80, body ~scroll 0.90
    titleThreshold = TRAVEL_END + (1 - TRAVEL_END) * 0.76;
    bodyThreshold  = TRAVEL_END + (1 - TRAVEL_END) * 0.88;
    if (scrollSmooth > titleThreshold) heroTitleEl.classList.add('visible');
    else                                heroTitleEl.classList.remove('visible');
  }
  if (scrollSmooth > bodyThreshold) heroBodyEl.classList.add('visible');
  else                               heroBodyEl.classList.remove('visible');

  // ── HUD ──
  const shown = Math.min(Math.round(Math.max(revealFront,1)), N);
  nodeCountEl.textContent    = shown === 1 ? '1 node' : `${shown} nodes`;
  scrollHintEl.style.opacity = scrollSmooth > 0.04 ? '0' : '0.22';

  renderer.render(scene, camera);
}
animate();
</script>
</body>
</html>
